# ===========================================
# Copy to .env and fill in your values
# ===========================================

# ═══════════════════════════════════════════
# Automation wizard (/scripts)
# ═══════════════════════════════════════════
# Unset: wizard only in NODE_ENV=development. 1 = enable in prod builds; 0 = disable everywhere.
ALLOW_SCRIPTS_WIZARD=1

# ═══════════════════════════════════════════
# LLM — DeepSeek
# ═══════════════════════════════════════════
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ═══════════════════════════════════════════
# LLM — Kimi (Moonshot)
# ═══════════════════════════════════════════
# LLM_PROVIDER=kimi
# MOONSHOT_API_KEY=
# MOONSHOT_API_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=kimi-k2.5

# ═══════════════════════════════════════════
# TTS — Edge
# ═══════════════════════════════════════════
EDGE_TTS_VOICE=zh-CN-YunjianNeural
EDGE_TTS_BATCH_SIZE=3
